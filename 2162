#include <stdio.h>

int main()
{
    int maior;
    int menor;
    int n;
    int cont1 = 0;
    int cont2 = 0;
    scanf("%d", &n);
    int vetor[n];

    for (int i = 0; i < n; i++)
    {
        scanf("%d", &vetor[i]);
    }

    for (int i = 0; i < n; i++)
    {
        if (i != 0)
        {
            if (vetor[i] > vetor[i - 1])
            {
                cont1 = cont1 + 1;
                cont2 = 0;

                if (cont1 > 1)
                {
                    break;
                }
            }
            else if (vetor[i] < vetor[i - 1])
            {
                cont1 = 0;
                cont2 = cont2 + 1;

                if (cont2 > 1)
                {
                    break;
                }
            }
            else
            {
                cont1 = 2;
                cont2 = 2;
                break;
            }
        }
    }

    if (cont1 > 1 || cont2 > 1)
    {
        printf("0\n");
    }
    else
    {
        printf("1\n");
    }

    return 0;
}